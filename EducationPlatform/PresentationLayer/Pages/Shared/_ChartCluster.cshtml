@model (string Title, string PieId1, string Label1, int Total1, string PieId2, string Label2, int Total2)

<div style="width: 100%; box-sizing: border-box; display: inline-flex; vertical-align: stretch; margin-bottom: 20px;">
    
    <div style="background: #ffffff; border-radius: 12px; border: 1px solid #edf2f9; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; width: 100%; height: 100%; min-height: 420px; overflow: hidden;">
        
        <div style="padding: 20px 24px; background: #fff; border-bottom: 2px solid #f1f4f8; flex-shrink: 0;">
            <h6 style="margin: 0; font-weight: 800; color: #1a202c; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; display: flex; align-items: center; gap: 10px;">
                <span style="width: 4px; height: 16px; background: #4e73df; border-radius: 10px;"></span>
                @Model.Title
            </h6>
        </div>

        <div style="padding: 24px 15px; flex: 1; display: flex; flex-direction: column;">
            <div style="display: flex; flex-direction: row; flex-wrap: nowrap; align-items: flex-start; width: 100%; flex: 1;">
                
                <div style="flex: 1; padding: 0 15px; display: flex; flex-direction: column; align-items: center; border-right: 1px solid #f1f4f8;">
                    <div style="text-align: center; margin: 0 0 20px 0; color: #4e73df; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; background: #ebf0ff; padding: 6px 14px; border-radius: 30px; display: flex; gap: 8px; align-items: center;">
                        <span>@Model.Label1</span>
                        <span style="background: #4e73df; color: #fff; padding: 1px 8px; border-radius: 10px; font-size: 0.65rem;">@Model.Total1.ToString("N0")</span>
                    </div>
                    
                    <div style="height: 160px; width: 160px; flex-shrink: 0; position: relative; margin-bottom: 30px;">
                        <canvas id="@Model.PieId1"></canvas>
                    </div>

                    <div id="@(Model.PieId1)-legend" class="cluster-legend-grid">
                        @* JS Injected *@
                    </div>
                </div>

                <div style="flex: 1; padding: 0 15px; display: flex; flex-direction: column; align-items: center;">
                    <div style="text-align: center; margin: 0 0 20px 0; color: #4e73df; font-weight: 800; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px; background: #ebf0ff; padding: 6px 14px; border-radius: 30px; display: flex; gap: 8px; align-items: center;">
                        <span>@Model.Label2</span>
                        <span style="background: #4e73df; color: #fff; padding: 1px 8px; border-radius: 10px; font-size: 0.65rem;">@Model.Total2.ToString("N0")</span>
                    </div>
                    
                    <div style="height: 160px; width: 160px; flex-shrink: 0; position: relative; margin-bottom: 30px;">
                        <canvas id="@Model.PieId2"></canvas>
                    </div>

                    <div id="@(Model.PieId2)-legend" class="cluster-legend-grid">
                        @* JS Injected *@
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>

<style>
    .cluster-legend-grid {
        display: grid; 
        grid-template-columns: repeat(2, 1fr); 
        gap: 5px 15px; 
        width: 100%; 
        padding: 0 5px;
    }
    .legend-item { display: flex; align-items: center; gap: 6px; width: 100%; padding: 2px 0; }
    .legend-color { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }
    .legend-label { 
        font-size: 0.75rem; 
        color: #4a5568; 
        font-weight: 600; 
        display: flex; 
        justify-content: space-between; 
        width: 100%;
        white-space: nowrap;
        overflow: hidden;
    }
    .legend-val { color: #1a202c; font-weight: 800; margin-left: 4px; }
</style>