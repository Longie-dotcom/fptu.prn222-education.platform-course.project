@model (string Title, string Id)

<div style="width: 100%; margin-bottom: 24px;" id="container-@Model.Id">
    <div style="background: #ffffff; border-radius: 12px; border: 1px solid #edf2f9; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; overflow: hidden;">
        
        <div style="padding: 16px 20px; background: #fff; border-bottom: 1px solid #f1f4f8; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
            <div style="display: flex; align-items: center; gap: 10px;">
                <span style="width: 4px; height: 16px; background: #4e73df; border-radius: 10px;"></span>
                <h6 style="margin: 0; font-weight: 800; color: #1a202c; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px;">@Model.Title</h6>
            </div>

            <div style="display: flex; align-items: center; gap: 8px;">
                <div style="display: flex; gap: 12px; align-items: center; margin-right: 12px;">
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 8px; height: 8px; background: #4e73df; border-radius: 2px;"></span>
                        <span style="font-size: 0.65rem; font-weight: 800; color: #718096;">DEMAND</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 6px;">
                        <span style="width: 8px; height: 8px; background: #c5cff5; border-radius: 2px;"></span>
                        <span style="font-size: 0.65rem; font-weight: 800; color: #718096;">SUPPLY</span>
                    </div>
                </div>

                <div class="range-input-group" style="display: flex; align-items: center; background: #ebf0ff; border: 1px solid #d1dcfd; border-radius: 8px; padding: 2px 8px;">
                    <span style="font-size: 0.65rem; font-weight: 800; color: #4e73df; margin-right: 5px;">RANGE</span>
                    <input type="date" class="from-date"
                           value="@DateTime.Now.AddMonths(-3).ToString("yyyy-MM-dd")"
                           onchange="fetchDemandSupplyData()"
                           style="border: none; background: transparent; font-size: 0.75rem; color: #4e73df; outline: none; padding: 4px; font-weight: 600; cursor: pointer;">
                    <span style="color: #4e73df; opacity: 0.5;">—</span>
                    <input type="date" class="to-date"
                           value="@DateTime.Now.ToString("yyyy-MM-dd")"
                           onchange="fetchDemandSupplyData()"
                           style="border: none; background: transparent; font-size: 0.75rem; color: #4e73df; outline: none; padding: 4px; font-weight: 600; cursor: pointer;">
                </div>

                <select class="group-by" onchange="fetchDemandSupplyData()"
                        style="background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 12px; font-size: 0.75rem; color: #1a202c; font-weight: 700; outline: none; cursor: pointer;">
                    <option value="Day">Daily</option>
                    <option value="Month" selected>Monthly</option>
                    <option value="Year">Yearly</option>
                </select>
            </div>
        </div>

        <div style="padding: 24px; flex: 1; min-height: 400px; position: relative;">
            <canvas id="@Model.Id"></canvas>
        </div>
    </div>
</div>