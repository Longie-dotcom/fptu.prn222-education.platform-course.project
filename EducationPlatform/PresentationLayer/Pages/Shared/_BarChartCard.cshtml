@model (string Title, string Id)

<div style="width: 100%; margin-bottom: 24px; box-sizing: border-box; display: flex;">
    <div style="background: #ffffff; border-radius: 12px; border: 1px solid #edf2f9; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; width: 100%; overflow: hidden;">
        
        <div style="padding: 18px 24px; background: #fff; border-bottom: 2px solid #f1f4f8; display: flex; justify-content: space-between; align-items: center;">
            <h6 style="margin: 0; font-weight: 800; color: #1a202c; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px; display: flex; align-items: center; gap: 10px;">
                <span style="width: 4px; height: 16px; background: #4e73df; border-radius: 10px;"></span>
                @Model.Title
            </h6>
            
            <div id="@(Model.Id)-legend" style="display: flex; gap: 20px;">
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="width: 12px; height: 12px; background: #002060; border-radius: 3px;"></span>
                    <span style="font-size: 0.75rem; font-weight: 700; color: #4a5568;">Enrollment</span>
                </div>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <span style="width: 12px; height: 12px; background: #4e73df; border-radius: 3px;"></span>
                    <span style="font-size: 0.75rem; font-weight: 700; color: #4a5568;">Courses</span>
                </div>
            </div>
        </div>

        <div style="padding: 24px; flex: 1; min-height: 350px;">
            <canvas id="@Model.Id"></canvas>
        </div>
    </div>
</div>