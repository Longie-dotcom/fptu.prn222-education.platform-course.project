@model (string Title, string Id, int Total)

<div style="width: 32%; margin-bottom: 20px; box-sizing: border-box; display: inline-flex; vertical-align: stretch;">
    
    <div style="background: #fff; border-radius: 8px; border: 1px solid #e3e6f0; box-shadow: 0 .125rem .25rem rgba(0,0,0,.075); display: flex; flex-direction: column; width: 100%; overflow: hidden;">
        
        <div style="padding: 12px 16px; border-bottom: 1px solid #f8f9fc; background: #fff;">
            <h6 style="margin: 0; font-weight: 700; color: #4e73df; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.5px;">
                @Model.Title
            </h6>

            <h6 style="margin: 0; font-weight: 800; color: #4e73df; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px;">
                TOTAL: <span style="color: #1a202c;">@Model.Total.ToString("N0")</span>
            </h6>
        </div>

        <div style="padding: 15px; flex: 1; display: flex; flex-direction: row; align-items: center; justify-content: space-between; min-height: 250px;">
            
            <div id="@(Model.Id)-legend" style="display: flex; flex-direction: column; gap: 10px; width: 120px; flex-shrink: 0; overflow: hidden;">
                @* JavaScript will inject the legend here *@
            </div>

            <div style="flex: 1; height: 180px; position: relative; min-width: 0; display: flex; justify-content: center;">
                <canvas id="@Model.Id"></canvas>
            </div>
            
        </div>
    </div>
</div>

<style>
    /* Styling for elements injected via JS generateLegend function */
    .legend-item { 
        display: flex; 
        align-items: center; 
        gap: 8px; 
        line-height: 1.4; 
    }
    .legend-color { 
        width: 10px; 
        height: 10px; 
        border-radius: 2px; /* Square icons look better with Pie charts */
        flex-shrink: 0; 
    }
    .legend-label { 
        font-size: 0.75rem; 
        color: #5a5c69; 
        white-space: nowrap; 
        overflow: hidden; 
        text-overflow: ellipsis; 
    }
</style>