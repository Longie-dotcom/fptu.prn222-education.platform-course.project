@model (string Title, string Id, IEnumerable<BusinessLayer.DTO.GradeDTO> Grades, IEnumerable<BusinessLayer.DTO.SubjectDTO> Subjects)

<div style="width: 100%; margin-bottom: 24px;" id="container-@Model.Id">
    <div style="background: #ffffff; border-radius: 12px; border: 1px solid #edf2f9; box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; overflow: hidden;">
        
        <div style="padding: 16px 20px; background: #fff; border-bottom: 1px solid #f1f4f8; display: flex; flex-direction: column; gap: 12px;">
            
            <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="width: 4px; height: 16px; background: #e74a3b; border-radius: 10px;"></span>
                    <h6 style="margin: 0; font-weight: 800; color: #1a202c; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px;">@Model.Title</h6>
                </div>

                <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px;">
                    <select class="master-revenue-type" onchange="fetchNormalizedData()"
                            style="background: #fff5f5; border: 1px solid #ffd8d8; border-radius: 8px; padding: 6px 10px; font-size: 0.75rem; font-weight: 700; color: #e74a3b; outline: none;">
                        <option value="All">Total Revenue</option>
                        <option value="Commission">Commission Only</option>
                        <option value="Teacher">Teacher Payouts</option>
                    </select>

                    <select class="master-grade" onchange="fetchNormalizedData()"
                            style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 10px; font-size: 0.75rem; font-weight: 700; color: #4a5568; outline: none;">
                        <option value="">All Grades</option>
                        @foreach (var g in Model.Grades)
                        {
                            <option value="@g.GradeID">@g.Name</option>
                        }
                    </select>

                    <select class="master-subject" onchange="fetchNormalizedData()"
                            style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 10px; font-size: 0.75rem; font-weight: 700; color: #4a5568; outline: none;">
                        <option value="">All Subjects</option>
                        @foreach (var s in Model.Subjects)
                        {
                            <option value="@s.SubjectID">@s.Name</option>
                        }
                    </select>

                    <select class="master-role" onchange="fetchNormalizedData()"
                            style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 10px; font-size: 0.75rem; font-weight: 700; color: #4a5568; outline: none;">
                        <option value="">All Roles</option>
                        <option value="Student">Students</option>
                        <option value="Teacher">Teachers</option>
                    </select>
                </div>
            </div>

            <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 12px; border-top: 1px dashed #edf2f9; padding-top: 10px;">
                <div class="range-input-group" style="display: flex; align-items: center; background: #fef2f2; border: 1px solid #fee2e2; border-radius: 8px; padding: 2px 8px;">
                    <span style="font-size: 0.65rem; font-weight: 800; color: #b91c1c; margin-right: 5px;">BASE 100 RANGE</span>
                    <input type="date" class="from-date" value="@DateTime.Now.AddMonths(-3).ToString("yyyy-MM-dd")" onchange="fetchNormalizedData()" style="border: none; background: transparent; font-size: 0.75rem; color: #b91c1c; outline: none; padding: 4px; font-weight: 600;">
                    <span style="color: #b91c1c; opacity: 0.5;">—</span>
                    <input type="date" class="to-date" value="@DateTime.Now.ToString("yyyy-MM-dd")" onchange="fetchNormalizedData()" style="border: none; background: transparent; font-size: 0.75rem; color: #b91c1c; outline: none; padding: 4px; font-weight: 600;">
                </div>

                <select class="group-by" onchange="fetchNormalizedData()" style="background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 6px 12px; font-size: 0.75rem; color: #1a202c; font-weight: 700; outline: none; cursor: pointer;">
                    <option value="Day">Daily</option>
                    <option value="Month" selected>Monthly</option>
                    <option value="Year">Yearly</option>
                </select>
            </div>
        </div>

        <div style="padding: 24px; flex: 1; min-height: 400px;">
            <canvas id="@Model.Id"></canvas>
        </div>
    </div>
</div>