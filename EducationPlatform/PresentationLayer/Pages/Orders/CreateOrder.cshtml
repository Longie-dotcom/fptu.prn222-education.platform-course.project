@page "{id:Guid}"
@model PresentationLayer.Pages.Orders.CreateOrderModel
@{
    ViewData["Title"] = "Checkout";
    // Formatting helper
    string FormatVND(decimal amount) => amount > 0 ? string.Format("{0:N0} VND", amount) : "0 VND";
}

<div style="max-width: 1100px; margin: 30px auto; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #1e293b; line-height: 1.6;">
    
    @* --- BACK LINK --- *@
    <div style="margin-bottom: 20px;">
        <a asp-page="/Courses/DetailCourse" asp-route-id="@Model.Course.CourseID" style="text-decoration: none; color: #64748b; font-size: 0.9rem; display: flex; align-items: center; gap: 5px;">
            ← Back to Course Details
        </a>
    </div>

    <form method="post" asp-page-handler="CreateOrder">
        @* Hidden field to pass courseId to OnPost *@
        <input type="hidden" name="courseId" value="@Model.Course.CourseID" />

        <div style="display: flex; gap: 30px; align-items: flex-start;">
            
            @* ===== LEFT COLUMN: ORDER INFO & VOUCHERS ===== *@
            <div style="flex: 1;">
                
                @* Course Review Card *@
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 25px; margin-bottom: 25px; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
                    <h5 style="margin: 0 0 20px 0; color: #1e1b4b; font-weight: 700; display: flex; align-items: center; gap: 10px;">
                        <span style="background: #4834d4; width: 4px; height: 18px; border-radius: 2px;"></span>
                        Review Purchase
                    </h5>

                    <div style="display: flex; gap: 20px;">
                        @if (!string.IsNullOrEmpty(Model.Course.ThumbnailName))
                        {
                            <img src="~/media/@Model.Course.ThumbnailName" style="width: 200px; height: 120px; object-fit: cover; border-radius: 12px; border: 1px solid #f1f5f9;" alt="Thumbnail" />
                        }
                        else
                        {
                            <div style="width: 200px; height: 120px; background: #f8fafc; border-radius: 12px; border: 2px dashed #e2e8f0; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-size: 0.8rem;">No Thumbnail</div>
                        }

                        <div style="flex: 1;">
                            <h4 style="margin: 0 0 5px 0; color: #1e1b4b; font-size: 1.25rem;">@Model.Course.Title</h4>
                            <p style="margin: 0 0 12px 0; color: #64748b; font-size: 0.9rem;">Instructor: <span style="font-weight: 600; color: #4834d4;">@Model.Course.Teacher.Name</span></p>
                            
                            <div style="display: flex; gap: 8px;">
                                <span style="background: #eef2ff; color: #4338ca; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600;">@Model.Course.Grade.Name</span>
                                <span style="background: #ecfdf5; color: #065f46; padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; font-weight: 600;">@Model.Course.Subject.Name</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* Vouchers Section *@
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 25px; box-shadow: 0 4px 20px rgba(0,0,0,0.04);">
                    <h5 style="margin: 0 0 15px 0; color: #1e1b4b; font-weight: 700;">Select Vouchers</h5>
                    
                    @if (Model.Coupons != null && Model.Coupons.Any())
                    {
                        <div style="display: grid; gap: 12px;">
                            @foreach (var coupon in Model.Coupons)
                            {
                                <label style="border: 1px solid #e2e8f0; background: #fafbfc; border-radius: 12px; padding: 15px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.borderColor='#4834d4'" onmouseout="this.style.borderColor='#e2e8f0'">
                                    <div style="display: flex; align-items: center; gap: 15px;">
                                        @* Checkbox binds to SelectedCouponIds *@
                                        <input type="checkbox" name="SelectedCouponIds" value="@coupon.CouponID"
                                        @(Model.SelectedCouponIds != null && Model.SelectedCouponIds.Contains(coupon.CouponID) ? "checked" : "")
                                               style="width: 18px; height: 18px; accent-color: #4834d4;"
                                               data-amount="@coupon.DiscountAmount"
                                               onchange="updateSummary()" />
                                        
                                        <div>
                                            <div style="font-family: 'Courier New', monospace; font-weight: 800; color: #4338ca; font-size: 1.1rem; line-height: 1;">@coupon.Code</div>
                                            <div style="font-size: 0.8rem; color: #64748b; margin-top: 4px;">@coupon.Reason</div>
                                        </div>
                                    </div>
                                    <div style="text-align: right;">
                                        <div style="font-weight: 700; color: #059669;">-@FormatVND(coupon.DiscountAmount)</div>
                                        <div style="font-size: 0.7rem; color: #94a3b8; text-transform: uppercase;">Discount</div>
                                    </div>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="padding: 20px; text-align: center; background: #f8fafc; border-radius: 10px; border: 1px solid #f1f5f9; color: #94a3b8; font-size: 0.9rem;">
                            No vouchers available at this time.
                        </div>
                    }
                </div>
            </div>

            @* ===== RIGHT COLUMN: SUMMARY & PAY ===== *@
            <div style="flex: 0 0 380px; position: sticky; top: 30px;">
                <div style="background: white; border: 1px solid #e2e8f0; border-radius: 16px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.08);">
                    <h5 style="margin: 0 0 20px 0; color: #1e1b4b; font-weight: 700;">Order Summary</h5>
        
                    @* Base Price *@
                    <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 0.95rem;">
                        <span style="color: #64748b;">Course Price</span>
                        <span style="font-weight: 600;">@FormatVND(Model.Course.Price ?? 0)</span>
                    </div>
        
                    @* Dynamic Discount List (Populated by JS) *@
                    <div id="applied-discounts-list" style="border-top: 1px dashed #f1f5f9; margin-top: 10px; padding-top: 10px;">
                        @* Items will be injected here *@
                    </div>
        
                    <div style="display: flex; justify-content: space-between; margin: 12px 0; font-size: 0.95rem;">
                        <span style="color: #64748b;">Total Savings</span>
                        <span id="summary-discount" style="color: #059669; font-weight: 700;">0 VND</span>
                    </div>

                    <hr style="border: 0; border-top: 1px solid #f1f5f9; margin: 20px 0;">

                    <div style="display: flex; justify-content: space-between; margin-bottom: 30px;">
                        <span style="font-weight: 700; font-size: 1.1rem; color: #1e1b4b;">Total Amount</span>
                        <span id="summary-total" style="font-weight: 800; font-size: 1.4rem; color: #4834d4;">@FormatVND(Model.Course.Price ?? 0)</span>
                    </div>

                    <button type="submit" style="width: 100%; background: #4834d4; color: white; border: none; padding: 16px; border-radius: 12px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.2s; box-shadow: 0 4px 12px rgba(72, 52, 212, 0.3);"
                            onmouseover="this.style.background='#3c2bb3'; this.style.transform='translateY(-1px)';"
                            onmouseout="this.style.background='#4834d4'; this.style.transform='translateY(0)';"
                            onclick="this.innerHTML='Connecting to PayOS...'; this.style.opacity='0.8';">
                        Enroll & Pay Now
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@* Toast for Errors *@
@if (TempData["ToastMessage"] != null)
{
    <div id="toast" style="position: fixed; bottom: 30px; right: 30px; background: @(TempData["ToastType"]?.ToString() == "danger" ? "#ef4444" : "#10b981"); color: white; padding: 16px 24px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); z-index: 9999; font-weight: 600; display: flex; align-items: center; gap: 10px;">
        <span>@(TempData["ToastType"]?.ToString() == "danger" ? "⚠️" : "✅")</span>
        @TempData["ToastMessage"]
    </div>
    <script>setTimeout(() => { document.getElementById('toast').style.display = 'none'; }, 5000);</script>
}
<script>
    const basePrice = parseFloat("@(Model.Course.Price ?? 0)");

    function updateSummary() {
    let totalDiscount = 0;
    const discountListContainer = document.getElementById('applied-discounts-list');
    const allCheckboxes = document.querySelectorAll('input[name="SelectedCouponIds"]');
    const checkedCheckboxes = document.querySelectorAll('input[name="SelectedCouponIds"]:checked');
        
    discountListContainer.innerHTML = '';

    checkedCheckboxes.forEach(cb => {
    const amount = parseFloat(cb.getAttribute('data-amount')) || 0;
    const codeElement = cb.closest('label').querySelector('div[style*="font-family"]');
    const code = codeElement ? codeElement.innerText : "Discount";
            
    totalDiscount += amount;

    const item = document.createElement('div');
    item.style.display = "flex";
    item.style.justifyContent = "space-between";
    item.style.fontSize = "0.85rem";
    item.style.color = "#059669";
    item.style.marginBottom = "5px";
    item.innerHTML = `<span>Code: <b>${code}</b></span><span>-${formatVND(amount)}</span>`;
    discountListContainer.appendChild(item);
    });

    discountListContainer.style.display = checkedCheckboxes.length > 0 ? 'block' : 'none';

    const finalTotal = Math.max(0, basePrice - totalDiscount);

    // --- NEW LOGIC: PREVENT FURTHER SELECTION ---
    allCheckboxes.forEach(cb => {
    // If price is 0 or less, disable all checkboxes that ARE NOT currently checked
    if (finalTotal <= 0 && !cb.checked) {
    cb.disabled = true;
    cb.closest('label').style.opacity = "0.5";
    cb.closest('label').style.cursor = "not-allowed";
    } else {
    // Re-enable if the user unchecks a box and price goes above 0
    cb.disabled = false;
    cb.closest('label').style.opacity = "1";
    cb.closest('label').style.cursor = "pointer";
    }
    });

    document.getElementById('summary-discount').innerText = formatVND(totalDiscount);
    document.getElementById('summary-total').innerText = formatVND(finalTotal);
    }

    function formatVND(amount) {
    return amount.toLocaleString('vi-VN') + " VND";
    }

    document.addEventListener('DOMContentLoaded', () => {
    updateSummary();
    });
</script>