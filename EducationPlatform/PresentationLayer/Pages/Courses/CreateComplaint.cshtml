@page "{courseId:guid}"
@model PresentationLayer.Pages.Courses.CreateComplaintModel
@{
    ViewData["Title"] = "Formal Course Grievance";
}

<div style="max-width: 1000px; margin: 40px auto; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #2d3436;">
    
    @* Header Section *@
    <div style="margin-bottom: 30px; border-bottom: 2px solid #f1f2f6; padding-bottom: 20px;">
        <h1 style="color: #2d3436; font-size: 2rem; margin-bottom: 10px;">Submit a Formal Complaint</h1>
        <p style="color: #636e72; line-height: 1.6;">
            Our quality assurance team reviews every report. Please provide detailed information regarding your experience
            with this course. Formal grievances help us maintain our community standards
            and ensure a high-quality learning environment for everyone.
        </p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 300px; gap: 40px;">
        
        @* Main Form Column *@
        <section>
            <div style="background: #fff; padding: 30px; border-radius: 16px; border: 1px solid #dfe6e9; box-shadow: 0 10px 25px rgba(0,0,0,0.03);">
                <form method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CourseId" />

                    <div style="margin-bottom: 25px;">
                        <label asp-for="Reason" style="display: block; font-weight: 700; margin-bottom: 8px; color: #2d3436;">Detailed Statement of Complaint</label>
                        <p style="font-size: 0.85rem; color: #636e72; margin-bottom: 10px;">
                            Please describe the issue in detail. Include specific dates, course modules, or interactions where applicable.
                        </p>
                        <textarea asp-for="Reason"
                                  placeholder="Type your explanation here..."
                                  style="width: 96%; min-height: 180px; padding: 2%; border-radius: 10px; border: 1px solid #dcdde1; font-size: 1rem; transition: border 0.3s; resize: vertical;"></textarea>
                        <span asp-validation-for="Reason" style="color: #d63031; font-size: 0.85rem; margin-top: 5px; display: block;"></span>
                    </div>

                    <div style="margin-bottom: 30px; padding: 20px; background: #f8f9fa; border-radius: 10px; border: 1px dashed #b2bec3;">
                        <label asp-for="EvidenceImage" style="display: block; font-weight: 700; margin-bottom: 5px;">Supporting Evidence</label>
                        <p style="font-size: 0.85rem; color: #636e72; margin-bottom: 15px;">
                            Upload screenshots or documents (JPG, PNG, PDF) that support your claim. Visual evidence significantly speeds up the review process.
                        </p>
                        <input asp-for="EvidenceImage" type="file" style="font-size: 0.9rem;" />
                        <span asp-validation-for="EvidenceImage" style="color: #d63031; font-size: 0.85rem; display: block; margin-top: 5px;"></span>
                    </div>

                    <div style="display: flex; align-items: center; gap: 15px;">
                        <button type="submit"
                                style="background: #d63031; color: #fff; border: none; padding: 14px 30px; border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 1rem; transition: background 0.2s;">
                            Submit Official Report
                        </button>
                        <a href="/Courses/Details/@Model.CourseId" style="color: #636e72; text-decoration: none; font-size: 0.9rem;">Cancel and Return</a>
                    </div>
                </form>
            </div>
        </section>

        @* Sidebar Information *@
        <aside>
            <div style="margin-bottom: 30px;">
                <h3 style="font-size: 1.1rem; margin-bottom: 15px; color: #2d3436;">Review Process</h3>
                <ul style="padding: 0; list-style: none; font-size: 0.9rem; color: #636e72; line-height: 1.8;">
                    <li style="margin-bottom: 10px; display: flex; gap: 10px;">
                        <span style="background: #e74c3c; color: #fff; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; flex-shrink: 0;">1</span>
                        Initial screening by QA within 24 hours.
                    </li>
                    <li style="margin-bottom: 10px; display: flex; gap: 10px;">
                        <span style="background: #e74c3c; color: #fff; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; flex-shrink: 0;">2</span>
                        Instructor notification & rebuttal period.
                    </li>
                    <li style="margin-bottom: 10px; display: flex; gap: 10px;">
                        <span style="background: #636e72; color: #fff; width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; flex-shrink: 0;">3</span>
                        Final Resolution & Email notification.
                    </li>
                </ul>
            </div>

            <div style="padding: 20px; background: #fff3f3; border-radius: 12px; border-left: 4px solid #d63031;">
                <h4 style="margin: 0 0 10px 0; color: #d63031; font-size: 1rem;">Confidentiality</h4>
                <p style="font-size: 0.85rem; color: #2d3436; margin: 0; line-height: 1.5;">
                    Complaints are handled with strict confidentiality. Your identity will not be shared with the instructor without your explicit consent unless required for the investigation.
                </p>
            </div>
        </aside>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}