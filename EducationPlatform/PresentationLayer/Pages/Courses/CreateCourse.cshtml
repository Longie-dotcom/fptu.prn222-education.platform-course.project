@page
@model PresentationLayer.Pages.Courses.CreateCourseModel
@{
    ViewData["Title"] = "Create Course";
}

<div style="max-width: 1700px; margin: 0 auto; padding: 20px; font-family: 'Segoe UI', sans-serif; padding-bottom: 100px;">
    <h2 style="color: #2d3436; font-weight: 700; margin-bottom: 25px;">Create New Course</h2>

    <form method="post" enctype="multipart/form-data" id="courseForm">
        @Html.AntiForgeryToken()
        <div style="display: flex; gap: 30px; align-items: flex-start;">

            <div style="flex: 0 0 250px; position: sticky; top: 20px; max-height: 85vh; overflow-y: auto; background: #f8fafc; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0;">
                <h4 style="margin: 0 0 15px 0; font-size: 1rem; color: #4834d4;">Course Map</h4>
                <div id="sidebar-nav" style="display: flex; flex-direction: column; gap: 8px;"></div>
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #e2e8f0;">
                <button type="submit" style="width: 100%; background: #4834d4; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: 600; cursor: pointer;">Create Course</button>
            </div>

            <div style="flex: 1;">
                <div style="background: white; padding: 30px; border-radius: 15px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-bottom: 30px;">
                    <h3 style="margin-top:0; margin-bottom:20px; font-size: 1.1rem; color: #4834d4;">Step 1: General Details</h3>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
                        <div style="grid-column: span 2;">
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Course Title</label>
                            <input asp-for="VM.CreateCourseDTO.Title" placeholder="Enter course title" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px;" />
                        </div>
                        <div style="grid-column: span 2;">
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Course Description</label>
                            <textarea asp-for="VM.CreateCourseDTO.Description" rows="4" placeholder="Provide a detailed overview of what this course covers..." style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px; font-family: inherit; resize: vertical;"></textarea>
                        </div>
                        <div>
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Prerequisites</label>
                            <textarea asp-for="VM.CreateCourseDTO.Prerequisites" placeholder="What should students know before?" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px;"></textarea>
                        </div>
                        <div>
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Learning Outcomes</label>
                            <textarea asp-for="VM.CreateCourseDTO.LearningOutcomes" placeholder="What will they achieve?" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px;"></textarea>
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
                        <div>
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Price (VND)</label>
                            <input asp-for="VM.CreateCourseDTO.Price" type="number" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px;" />
                        </div>
                        <div>
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Grade</label>
                            <select asp-for="VM.CreateCourseDTO.GradeID" asp-items="@(new SelectList(Model.VM.Grades, "GradeID", "Name"))" style="width: 100%; padding: 10px; border: 1px solid #e2e8f0; border-radius: 8px;"></select>
                        </div>
                        <div>
                            <label style="font-weight: 600; display: block; margin-bottom: 8px;">Subject</label>
                            <select asp-for="VM.CreateCourseDTO.SubjectID" asp-items="@(new SelectList(Model.VM.Subjects, "SubjectID", "Name"))" style="width: 100%; padding: 10px; border: 1px solid #e2e8f0; border-radius: 8px;"></select>
                        </div>
                    </div>

                    <div style="margin-bottom: 25px;">
                        <label style="font-weight: 600; display: block; margin-bottom: 8px;">Course Thumbnail</label>
                        <div style="display: flex; gap: 20px; align-items: center;">
                            <div id="preview-container" style="display: none; width: 150px; height: 100px; border-radius: 8px; overflow: hidden; border: 1px solid #e2e8f0;">
                                <img id="thumbnail-preview" src="#" style="width: 100%; height: 100%; object-fit: cover;" />
                            </div>
                            <div style="flex: 1;">
                                <input type="file"
                                       asp-for="VM.Thumbnail"
                                       id="thumbnail-input"
                                       accept="image/*"
                                       onchange="previewThumbnail()"
                                       style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 8px; background: #f8fafc;" />
                                <p style="font-size: 0.8rem; color: #64748b; margin: 5px 0 0 0;">Recommended: 16:9 aspect ratio (e.g., 1280x720px)</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="chapters-container"></div>

                <button type="button" onclick="addChapter()" style="width: 100%; padding: 20px; background: #f0f7ff; border: 2px dashed #4834d4; color: #4834d4; border-radius: 12px; font-weight: 700; cursor: pointer;">
                    + ADD NEW CHAPTER
                </button>
            </div>
        </div>
    </form>
</div>

<div id="templates" style="display:none;">
    <div class="chapter-block" style="background: white; border: 1px solid #e2e8f0; border-radius: 15px; padding: 25px; margin-bottom: 30px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h3 class="chapter-label" style="margin:0; color: #1e293b;">Chapter 1</h3>
            <button type="button" onclick="this.closest('.chapter-block').remove(); reindex();" style="color:#f87171; background:none; border:none; cursor:pointer; font-weight:600;">Delete Chapter</button>
        </div>
        <input class="chapter-title" oninput="reindex()" placeholder="Chapter Title" style="width: 96%; padding: 2%; border: 1px solid #cbd5e0; border-radius: 8px; margin-bottom: 10px;" />
        <textarea class="chapter-description" placeholder="Chapter Description" style="width: 96%; padding: 2%; border: 1px solid #cbd5e0; border-radius: 8px; margin-bottom: 20px;"></textarea>
        <input type="hidden" class="chapter-order" />
        <div class="lessons-container" style="display: flex; flex-direction: column; gap: 20px;"></div>

        <button type="button" onclick="addLesson(this)" style="margin-top:15px; background:none; border:1px solid #4834d4; color:#4834d4; padding:8px 16px; border-radius:6px; cursor:pointer; font-weight:600;">+ Add Lesson</button>
    </div>

    <div class="lesson-block" style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <h4 class="lesson-label" style="margin:0; color: #64748b; font-size: 0.85rem;">Lesson 1</h4>
            <button type="button" onclick="this.closest('.lesson-block').remove(); reindex();" style="color:#94a3b8; border:none; background:none; cursor:pointer;">&times; Remove Lesson</button>
        </div>

        <input class="lesson-title" oninput="reindex()" placeholder="Lesson Title" style="width: 96%; padding: 2%; border: 1px solid #cbd5e0; border-radius: 8px; margin-bottom: 10px;" />
        <textarea class="lesson-objectives" placeholder="Learning Objectives" style="width: 96%; padding: 2%; border: 1px solid #cbd5e0; border-radius: 8px; margin-bottom: 10px;"></textarea>

        <div style="margin-bottom: 15px;">
            <label style="font-size: 0.8rem; font-weight: 600; color: #64748b; display: block; margin-bottom: 5px;">Lesson Video</label>

            <video class="lesson-video-preview" controls style="width: 100%; border-radius: 8px; background: #000; margin-bottom: 10px; display: none; max-height: 250px;"></video>

            <div class="video-skeleton" style="display: none; background: #edf2f7; border-radius: 8px; padding: 20px; text-align: center; margin-bottom: 10px;">
                <div style="font-size: 0.8rem; margin-bottom: 8px; color: #4a5568;">Uploading Video... <span class="progress-percent">0%</span></div>
                <div style="width: 100%; background: #e2e8f0; height: 8px; border-radius: 4px; overflow: hidden;">
                    <div class="progress-bar" style="width: 0%; height: 100%; background: #4834d4; transition: width 0.3s;"></div>
                </div>
            </div>

            <div style="display: flex; gap: 8px;">
                <input class="lesson-video-url"
                       oninput="updateVideoPreview(this)"
                       placeholder="Paste Video URL or upload below"
                       style="flex: 1; padding: 10px; border: 1px solid #cbd5e0; border-radius: 8px;" />

                <label style="background: #e2e8f0; padding: 10px; border-radius: 8px; cursor: pointer; display: flex; align-items: center;">
                    <span style="font-size: 1.2rem;">📁</span>
                    <input type="file" accept="video/*" onchange="uploadLessonVideo(this)" style="display: none;">
                </label>
            </div>
        </div>

        <div class="quizzes-container" style="margin-bottom:10px;"></div>
        <div class="assignments-container" style="margin-bottom:10px;"></div>

        <div style="display: flex; gap: 10px; margin-top: 10px;">
            <button type="button" onclick="addQuiz(this)" style="font-size:0.75rem; padding: 5px 10px; border-radius:4px; border:1px solid #4834d4; color:#4834d4; background:white; cursor:pointer;">+ Add Quiz</button>
            <button type="button" onclick="addAssignment(this)" style="font-size:0.75rem; padding: 5px 10px; border-radius:4px; border:1px solid #27ae60; color:#27ae60; background:white; cursor:pointer;">+ Add Assignment</button>
        </div>
    </div>

    <div class="quiz-block" style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px; margin-bottom: 10px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
            <span style="font-size: 0.75rem; font-weight: bold; color: #4834d4;">QUIZ</span>
            <button type="button" onclick="this.closest('.quiz-block').remove(); reindex();" style="color:red; border:none; background:none; cursor:pointer;">&times;</button>
        </div>
        <input class="quiz-question" placeholder="Question" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 4px; margin-bottom: 8px;" />
        <select class="quiz-type" onchange="renderQuizAnswers(this)" style="width: 100%; padding: 8px; border: 1px solid #e2e8f0; border-radius: 4px; margin-bottom: 8px;">
            <option value="1">Multiple Choice (Single)</option>
            <option value="2">Multiple Choice (Multiple)</option>
            <option value="3">True/False</option>
        </select>
        <div class="options-container" style="display: flex; flex-direction: column; gap: 5px;"></div>
        <button type="button" class="add-opt-btn" onclick="addOption(this)" style="margin-top:5px; font-size:0.7rem; border:1px dashed #cbd5e0; background:none; cursor:pointer; width:100%; padding:5px;">+ Add Option</button>

        <input type="hidden" class="quiz-options-hidden" />
        <input type="hidden" class="quiz-correct-hidden" />
        <input type="hidden" class="quiz-tf-hidden" />
    </div>

    <div class="assignment-block" style="background: #f0fff4; border: 1px solid #c6f6d5; border-radius: 8px; padding: 15px; margin-bottom: 10px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
            <span style="font-size: 0.75rem; font-weight: bold; color: #27ae60;">ASSIGNMENT</span>
            <button type="button" onclick="this.closest('.assignment-block').remove(); reindex();" style="color:red; border:none; background:none; cursor:pointer;">&times;</button>
        </div>
        <input class="asn-title" placeholder="Assignment Title" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 4px; margin-bottom: 8px;" />
        <textarea class="asn-desc" placeholder="Instructions..." style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 4px; margin-bottom: 8px;"></textarea>
        <input class="asn-score" type="number" placeholder="Max Score" style="width: 96%; padding: 2%; border: 1px solid #e2e8f0; border-radius: 4px;" />
    </div>
</div>

<style>
    .nav-item {
        user-select: none; /* Prevent text selection while dragging */
        transition: background-color 0.2s;
    }

        .nav-item:hover {
            background-color: #f1f5f9 !important;
        }
    /* This class is added by SortableJS while dragging */
    .sortable-ghost {
        opacity: 0.4;
        background-color: #4834d4 !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script>
        const MEDIA_BASE_PATH = '@Url.Content("~/media/")';
                // 1. Listen for changes on Grade and Subject dropdowns
        const gradeSelect = document.getElementById('grade-select');
        const subjectSelect = document.getElementById('subject-select');
        const DRAFT_KEY = "course_draft";

        [gradeSelect, subjectSelect].forEach(select => {
            select.addEventListener('change', fetchDefaultLessons);
        });
        const navContainer = document.getElementById('sidebar-nav');

        function saveDraft() {
            const form = document.getElementById("courseForm");
            const data = new FormData(form);

            const obj = {};
            data.forEach((value, key) => {
                if (!(value instanceof File)) {
                    obj[key] = value;
                }
            });

            // count structure
            obj._chapters = document.querySelectorAll('.chapter-block').length;
            obj._lessons = [];

            document.querySelectorAll('.chapter-block').forEach(ch => {
                obj._lessons.push(ch.querySelectorAll('.lesson-block').length);
            });

            localStorage.setItem(DRAFT_KEY, JSON.stringify(obj));
        }

        setInterval(saveDraft, 5000);

        Sortable.create(navContainer, {
            animation: 150,
            handle: '.drag-handle',
            onEnd: function () {
                const container = document.getElementById('lessons-container');
                const navItems = navContainer.querySelectorAll('.nav-item');

                // Physically reorder the lesson blocks on the right
                navItems.forEach(item => {
                    const lessonId = item.getAttribute('data-for');
                    const block = document.getElementById(lessonId);
                    if (block) {
                        container.appendChild(block);
                    }
                });

                // This is the crucial part: refresh all numbers and indices
                reindex();
            }
        });

        function updateSidebar() {
            const nav = document.getElementById('sidebar-nav');
            nav.innerHTML = '';

            document.querySelectorAll("#lessons-container > .lesson-block").forEach((block, index) => {
                const id = `lesson-block-${index}`;
                block.id = id;
                const title = block.querySelector(".lesson-title").value || `Lesson ${index + 1}`;

                const navItem = document.createElement('div');
                navItem.className = 'nav-item';
                navItem.setAttribute('data-for', id);
                navItem.style.cssText = "background: white; padding: 10px; border-radius: 6px; border: 1px solid #e2e8f0; cursor: pointer; font-size: 0.85rem; display: flex; align-items: center; gap: 8px;";

                navItem.innerHTML = `
                    <span class="drag-handle" style="cursor: grab; color: #cbd5e0;">⠿</span>
                    <span onclick="document.getElementById('${id}').scrollIntoView({behavior: 'smooth'})" style="flex:1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                        <strong>L${index + 1}:</strong> ${title}
                    </span>
                `;
                nav.appendChild(navItem);
            });
        }

        // Add listeners to lesson titles to update sidebar in real-time
        document.addEventListener('input', (e) => {
            if (e.target.classList.contains('lesson-title')) {
                updateSidebar();
            }
        });

        async function fetchDefaultLessons() {
            const gradeId = gradeSelect.value;
            const subjectId = subjectSelect.value;

            // Only fetch if both are selected
            if (!gradeId || !subjectId) return;

            try {
                const response = await fetch(`?handler=DefaultLessons&subjectId=${subjectId}&gradeId=${gradeId}`);
                if (!response.ok) throw new Error("Failed to fetch lessons");

                const lessons = await response.json();

                // Clear current lessons and add the new ones
                const container = document.getElementById('lessons-container');
                container.innerHTML = '';

                lessons.forEach(lesson => {
                    // Reusing your existing addLesson logic but passing data
                    const template = document.querySelector('#templates .lesson-block').cloneNode(true);

                    // Populate the title and order from the DTO
                    template.querySelector(".lesson-title").value = lesson.title || lesson.name;
                    template.querySelector(".lesson-order").value = lesson.order;
                    if(lesson.description) template.querySelector(".lesson-description").value = lesson.description;
                    if(lesson.objectives) template.querySelector(".lesson-objectives").value = lesson.objectives;
                    
                    container.appendChild(template);
                });

                reindex(); // Important to fix the [index] names for the post request
            } catch (error) {
                console.error("Error fetching defaults:", error);
            }
        }

        function previewThumbnail() {
            const input = document.getElementById('thumbnail-input');
            const preview = document.getElementById('thumbnail-preview');
            const container = document.getElementById('preview-container');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { preview.src = e.target.result; container.style.display = 'block'; };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function addChapter() {
            const container = document.getElementById('chapters-container');
            const template = document.querySelector('#templates .chapter-block').cloneNode(true);
            container.appendChild(template);
            reindex();
        }

        function addLesson(btn) {
            const container = btn.closest('.chapter-block').querySelector('.lessons-container');
            const template = document.querySelector('#templates .lesson-block').cloneNode(true);
            container.appendChild(template);
            reindex();
        }

        function addAssignment(btn) {
            const container = btn.closest('.lesson-block').querySelector('.assignments-container');
            const template = document.querySelector('#templates .assignment-block').cloneNode(true);
            container.appendChild(template);
            reindex();
        }

        function addQuiz(btn) {
            const container = btn.closest('.lesson-block').querySelector('.quizzes-container');
            const template = document.querySelector('#templates .quiz-block').cloneNode(true);
            container.appendChild(template);
            const quizId = "q_" + Math.random().toString(36).substr(2, 9);
            template.setAttribute("data-quiz-id", quizId);
            renderQuizAnswers(template.querySelector('.quiz-type'));
            reindex();
        }

        function renderQuizAnswers(select) {
            const quizBlock = select.closest('.quiz-block');
            const area = quizBlock.querySelector('.options-container');
            const addBtn = quizBlock.querySelector('.add-opt-btn');
            const type = select.value;
            const quizId = quizBlock.getAttribute("data-quiz-id");
            area.innerHTML = '';

            if (type === "3") { // True/False
                addBtn.style.display = 'none';
                area.innerHTML = `
                    <div style="display: flex; flex-direction: column; gap: 10px;">
                        <label style="display: flex; align-items: center; gap: 12px; padding: 10px 15px; border: 1px solid #cbd5e0; border-radius: 8px; cursor: pointer;">
                            <input type="radio" name="${quizId}" value="True" onchange="collectQuizData(this)" style="width: 18px; height: 18px;">
                            <span>True</span>
                        </label>
                        <label style="display: flex; align-items: center; gap: 12px; padding: 10px 15px; border: 1px solid #cbd5e0; border-radius: 8px; cursor: pointer;">
                            <input type="radio" name="${quizId}" value="False" onchange="collectQuizData(this)" style="width: 18px; height: 18px;">
                            <span>False</span>
                        </label>
                    </div>`;
            } else {
                addBtn.style.display = 'block';
                addOption(addBtn);
            }
            collectQuizData(select);
        }

        function addOption(btn) {
            const quizBlock = btn.closest('.quiz-block');
            const container = quizBlock.querySelector('.options-container');
            const type = quizBlock.querySelector('.quiz-type').value;
            const quizId = quizBlock.getAttribute("data-quiz-id");
            const inputType = type === "1" ? "radio" : "checkbox";
            const groupName = type === "1" ? quizId : "opt_" + Math.random();
            const div = document.createElement('div');
            div.style.cssText = "display: flex; align-items: center; gap: 12px; padding: 8px 12px; border-radius: 8px; border: 1px solid #e2e8f0; background: white;";
            div.innerHTML = `
                <input type="${inputType}" name="${groupName}" class="opt-check" onchange="collectQuizData(this)" style="width: 18px; height: 18px;">
                <input type="text" class="opt-text" placeholder="Option text" oninput="collectQuizData(this)" style="flex:1; border: none; outline: none;">
                <button type="button" onclick="this.parentElement.remove(); collectQuizData(this)" style="color:#f87171; border:none; background:none; cursor:pointer;">&times;</button>
            `;
            container.appendChild(div);
        }

        function collectQuizData(el) {
            const quizBlock = el.closest('.quiz-block');
            if (!quizBlock) return;
            const type = quizBlock.querySelector('.quiz-type').value;
            const optionsContainer = quizBlock.querySelector('.options-container');
            let options = []; let corrects = []; let tfValue = "false";

            if (type === "3") {
                options = ["True", "False"];
                const selected = optionsContainer.querySelector('input[type="radio"]:checked');
                if (selected) {
                    tfValue = (selected.value === "True") ? "true" : "false";
                    corrects.push(selected.value);
                }
            } else {
                optionsContainer.querySelectorAll(':scope > div').forEach(row => {
                    const text = row.querySelector('.opt-text').value.trim();
                    const isChecked = row.querySelector('.opt-check').checked;
                    if (text) {
                        options.push(text);
                        if (isChecked) corrects.push(text);
                    }
                });
            }

            const optionsInput = quizBlock.querySelector('.quiz-options-hidden');
            const correctInput = quizBlock.querySelector('.quiz-correct-hidden');
            const tfInput = quizBlock.querySelector('.quiz-tf-hidden');

            optionsInput.value = JSON.stringify(options);
            correctInput.value = JSON.stringify(corrects);
            tfInput.value = tfValue;
        }

        function removeLesson(btn) { 
            btn.closest('.lesson-block').remove(); 
            reindex();             
        }

        function removeQuiz(btn) { 
            btn.closest('.quiz-block').remove(); 
            reindex();
        }

        function reindex() {
            const chapters = document.querySelectorAll('#chapters-container > .chapter-block');
            const sidebar = document.getElementById('sidebar-nav');
            sidebar.innerHTML = '';

            chapters.forEach((chapter, ci) => {
                const cPrefix = `VM.CreateCourseDTO.Chapters[${ci}]`;
                const displayOrder = ci + 1; // Chapter Order starts at 1

                // 1. Index Chapter Fields
                chapter.querySelector('.chapter-label').innerText = `Chapter ${displayOrder}`;
                chapter.querySelector('.chapter-title').name = `${cPrefix}.Title`;
                chapter.querySelector('.chapter-description').name = `${cPrefix}.Description`;

                // Ensure a hidden input for Order exists or set it if present
                let orderInput = chapter.querySelector('.chapter-order');
                if (orderInput) {
                    orderInput.name = `${cPrefix}.Order`;
                    orderInput.value = displayOrder;
                }

                // 2. Sidebar Chapter Header
                const cTitle = chapter.querySelector('.chapter-title').value || 'New Chapter';
                const cNav = document.createElement('div');
                cNav.style.cssText = "font-weight: bold; color: #4834d4; margin-top: 15px; font-size: 0.95rem; border-bottom: 1px solid #eee; padding-bottom: 5px;";
                cNav.innerHTML = `CH ${displayOrder}: ${cTitle}`;
                sidebar.appendChild(cNav);

                // 3. Index Lessons within this Chapter
                const lessons = chapter.querySelectorAll('.lessons-container > .lesson-block');
                lessons.forEach((lesson, li) => {
                    const lPrefix = `${cPrefix}.Lessons[${li}]`;
                    const lessonOrder = li + 1;
                    const lId = `c${ci}l${li}`;
                    lesson.id = lId;

                    // Update Lesson Labels and Inputs
                    lesson.querySelector('.lesson-label').innerText = `Lesson ${lessonOrder}`;
                    lesson.querySelector('.lesson-title').name = `${lPrefix}.Title`;
                    lesson.querySelector('.lesson-objectives').name = `${lPrefix}.Objectives`;
                    lesson.querySelector('.lesson-video-url').name = `${lPrefix}.VideoUrl`;

                    // Set Lesson Order
                    let lOrderInput = lesson.querySelector('.lesson-order');
                    if (lOrderInput) {
                        lOrderInput.name = `${lPrefix}.Order`;
                        lOrderInput.value = lessonOrder;
                    }

                    // 4. Sidebar Lesson Item
                    const lTitle = lesson.querySelector('.lesson-title').value || `Lesson ${lessonOrder}`;
                    const lNav = document.createElement('div');
                    lNav.className = 'nav-item';
                    lNav.style.cssText = "padding: 8px 10px; font-size: 0.85rem; cursor: pointer; border-left: 2px solid #e2e8f0; margin-left: 10px; margin-top: 4px; background: #fdfdfd; transition: 0.2s;";
                    lNav.innerHTML = `<span style="color: #64748b;">L${lessonOrder}:</span> ${lTitle}`;
                    lNav.onclick = () => document.getElementById(lId).scrollIntoView({behavior: 'smooth'});

                    // Hover effect for sidebar
                    lNav.onmouseenter = () => lNav.style.background = "#f1f5f9";
                    lNav.onmouseleave = () => lNav.style.background = "#fdfdfd";

                    sidebar.appendChild(lNav);

                    // 5. Index Quizzes within this Lesson
                    const quizzes = lesson.querySelectorAll('.quizzes-container > .quiz-block');
                    quizzes.forEach((quiz, qi) => {
                        const qPrefix = `${lPrefix}.Quizzes[${qi}]`;
                        quiz.querySelector('.quiz-question').name = `${qPrefix}.Question`;
                        quiz.querySelector('.quiz-type').name = `${qPrefix}.Answer.Type`;
                        quiz.querySelector('.quiz-options-hidden').name = `${qPrefix}.Answer.Options`;
                        quiz.querySelector('.quiz-correct-hidden').name = `${qPrefix}.Answer.CorrectAnswers`;
                        quiz.querySelector('.quiz-tf-hidden').name = `${qPrefix}.Answer.TrueOrFalse`;

                        // Set Quiz Order
                        let qOrderInput = quiz.querySelector('.quiz-order');
                        if (qOrderInput) {
                            qOrderInput.name = `${qPrefix}.Order`;
                            qOrderInput.value = qi + 1;
                        }
                    });

                    // 6. Index Assignments within this Lesson
                    const assigns = lesson.querySelectorAll('.assignments-container > .assignment-block');
                    assigns.forEach((asn, ai) => {
                        const asPrefix = `${lPrefix}.Assignments[${ai}]`;
                        asn.querySelector('.asn-title').name = `${asPrefix}.Title`;
                        asn.querySelector('.asn-desc').name = `${asPrefix}.Description`;
                        asn.querySelector('.asn-score').name = `${asPrefix}.MaxScore`;

                        // Set Assignment Order
                        let aOrderInput = asn.querySelector('.asn-order');
                        if (aOrderInput) {
                            aOrderInput.name = `${asPrefix}.Order`;
                            aOrderInput.value = ai + 1;
                        }
                    });
                });
            });
        }

        async function uploadLessonVideo(input) {
            const file = input.files[0];
            if (!file) return;

            const lessonBlock = input.closest(".lesson-block");
            const skeleton = lessonBlock.querySelector(".video-skeleton");
            const progressBar = lessonBlock.querySelector(".progress-bar");
            const percentText = lessonBlock.querySelector(".progress-percent");
            const videoPreview = lessonBlock.querySelector(".lesson-video-preview");
            const hiddenUrlInput = lessonBlock.querySelector(".lesson-video-url");

            // Init UI
            skeleton.style.display = 'block';
            videoPreview.style.display = 'none';
            progressBar.style.width = '0%';
            percentText.textContent = '0%';
            input.disabled = true;

            const uploadId = crypto.randomUUID();
            const chunkSize = 5 * 1024 * 1024; // 5MB
            const totalChunks = Math.ceil(file.size / chunkSize);
            let index = 0;

            try {
                while (index < totalChunks) {
                    const chunk = file.slice(index * chunkSize, (index + 1) * chunkSize);
                    const form = new FormData();
                    form.append("chunk", chunk);
                    form.append("uploadId", uploadId);
                    form.append("index", index);

                    await fetch("?handler=UploadChunk", {
                        method: "POST",
                        headers: {
                            "RequestVerificationToken": getCsrfToken()
                        },
                        body: form
                    });

                    index++;
                    // Update UI Progress (Limit to 95% until complete)
                    const percent = Math.floor((index / totalChunks) * 95);
                    progressBar.style.width = percent + '%';
                    percentText.textContent = percent + '%';
                }

                const ext = file.name.split('.').pop();
                const completeForm = new FormData();
                completeForm.append("uploadId", uploadId);
                completeForm.append("extension", ext);

                const res = await fetch("?handler=Complete", {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": getCsrfToken()
                    },
                    body: completeForm
                });
                if (!res.ok) throw new Error();

                const data = await res.json();

                // Finalize UI
                progressBar.style.width = '100%';
                percentText.textContent = '100%';

                setTimeout(() => {
                    skeleton.style.display = 'none';
                    hiddenUrlInput.value = data.url;
                    videoPreview.src = MEDIA_BASE_PATH + data.url;
                    videoPreview.style.display = 'block';
                }, 500);

            } catch (err) {
                alert("Upload failed");
                skeleton.style.display = 'none';
            } finally {
                input.disabled = false;
            }
        }

        function getCsrfToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function loadDraft() {
            const raw = localStorage.getItem(DRAFT_KEY);
            if (!raw) return;

            const data = JSON.parse(raw);

            // rebuild chapters
            if (data._chapters) {
                for (let i = 0; i < data._chapters; i++) {
                    addChapter();

                    const chapter = document.querySelectorAll('.chapter-block')[i];

                    const lessonCount = data._lessons[i] || 0;

                    for (let j = 0; j < lessonCount; j++) {
                        const btn = chapter.querySelector('button[onclick="addLesson(this)"]');
                        addLesson(btn);
                    }
                }
            }

            // restore values
            Object.keys(data).forEach(name => {
                const el = document.querySelector(`[name="${name}"]`);
                if (el) el.value = data[name];
            });

            reindex();
        }

        document.addEventListener("DOMContentLoaded", () => {
            loadDraft();
        });

        document.getElementById("courseForm").addEventListener("submit", function () {
            reindex();
            localStorage.removeItem(DRAFT_KEY);
        });

        document.addEventListener('DOMContentLoaded', () => {
            const navContainer = document.getElementById('sidebar-nav');
            if (navContainer) {
                Sortable.create(navContainer, {
                    animation: 150,
                    handle: '.drag-handle', // Only drag by the ⠿ icon
                    onEnd: function () {
                        const container = document.getElementById('lessons-container');
                        const navItems = navContainer.querySelectorAll('.nav-item');

                        navItems.forEach(item => {
                            const lessonId = item.getAttribute('data-for');
                            const block = document.getElementById(lessonId);
                            if (block) container.appendChild(block);
                        });

                        reindex(); // This will also refresh the sidebar labels
                    }
                });
            }
            updateSidebar();
        });
    </script>
}