@page "{id:guid}"
@model PresentationLayer.Pages.Courses.ReviewComplaintModel
@{
    ViewData["Title"] = "Review Complaint";
}

<div style="max-width: 850px; margin: 40px auto; font-family: 'Segoe UI', Arial, sans-serif;">
    <div style="background:#fff; padding:25px 30px; border-radius:18px; box-shadow:0 18px 45px rgba(15,23,42,0.08);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
            <h2 style="margin:0; font-size:1.4rem; font-weight:700; color:#1f2933;">Review Complaint</h2>
            <span style="padding:4px 10px; border-radius:999px; background:#ffefe6; color:#e46a1f; font-size:0.75rem; font-weight:600; text-transform:uppercase; letter-spacing:0.04em;">
                Pending
            </span>
        </div>

        <div style="display:grid; grid-template-columns:1.1fr 0.9fr; gap:24px; margin-bottom:20px;">
            <div style="border-right:1px solid #edf2f7; padding-right:20px;">
                <div style="margin-bottom:10px;">
                    <div style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280;">Course</div>
                    <div style="font-size:1rem; font-weight:600; color:#111827;">
                        @Model.Course.Title
                    </div>
                </div>

                <div style="display:flex; gap:24px; margin-bottom:10px;">
                    <div>
                        <div style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280;">Teacher</div>
                        <div style="font-size:0.95rem; color:#111827;">@Model.Course.Teacher.Name</div>
                    </div>
                    <div>
                        <div style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280;">Student</div>
                        <div style="font-size:0.95rem; color:#111827;">@Model.Complaint.User.Name</div>
                    </div>
                </div>

                <div>
                    <div style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.06em; color:#6b7280;">Created At</div>
                    <div style="font-size:0.9rem; color:#374151;">@Model.Complaint.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                </div>
            </div>

            <div>
                <div style="font-size:0.8rem; font-weight:600; color:#4b5563; margin-bottom:6px;">Reason</div>
                <div style="font-size:0.9rem; color:#111827; background:#f9fafb; border-radius:10px; padding:10px 12px; border:1px solid #e5e7eb; min-height:80px;">
                    @Model.Complaint.Reason
                </div>

                @if (!string.IsNullOrEmpty(Model.Complaint.EvidenceImagePath))
                {
                    <div style="margin-top:14px;">
                        <div style="font-size:0.8rem; font-weight:600; color:#4b5563; margin-bottom:6px;">Evidence</div>
                        <div style="border-radius:10px; overflow:hidden; border:1px solid #e5e7eb; background:#0f172a;">
                            <img src="~/media/@Model.Complaint.EvidenceImagePath"
                                 alt="Complaint evidence"
                                 style="width:100%; max-height:260px; object-fit:contain; background:#0f172a;" />
                        </div>
                    </div>
                }
            </div>
        </div>

        <form method="post" style="margin-top:10px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReviewDto.ComplaintID" />

            <div class="form-group" style="margin-bottom:16px;">
                <label asp-for="ReviewDto.AdminNote"
                       style="display:block; font-size:0.85rem; font-weight:600; color:#4b5563; margin-bottom:6px;">
                    Admin note
                </label>
                <textarea asp-for="ReviewDto.AdminNote"
                          class="form-control"
                          style="min-height:80px; border-radius:10px; border:1px solid #d1d5db;"></textarea>
                <span asp-validation-for="ReviewDto.AdminNote" class="text-danger" style="font-size:0.8rem;"></span>
            </div>

            <div style="display:flex; gap:10px;">
                <button type="submit" name="action" value="approve"
                        style="padding:8px 18px; border-radius:999px; border:none; background:#10b981; color:white; font-weight:600; font-size:0.9rem; box-shadow:0 10px 25px rgba(16,185,129,0.3);">
                    Approve
                </button>
                <button type="submit" name="action" value="reject"
                        style="padding:8px 18px; border-radius:999px; border:1px solid #f97373; background:#fff5f5; color:#e11d48; font-weight:600; font-size:0.9rem;">
                    Reject
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

