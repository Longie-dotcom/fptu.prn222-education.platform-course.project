@page
@model PresentationLayer.Pages.AISupports.AISupportModel
@{
    ViewData["Title"] = "AI Learning Assistant";
    var primaryColor = "#4834d4";
    var accentColor = "#686de0";
}

<div style="max-width: 1200px; margin: 40px auto; font-family: 'Inter', 'Segoe UI', sans-serif; padding: 0 20px;">

    @* --- Header --- *@
    <div style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); margin-bottom: 30px; border-left: 8px solid @primaryColor;">
        <h2 style="margin: 0; color: #1a1a1a; font-size: 1.8rem;">Video Transcript Quizzer 🤖</h2>
        <p style="margin: 8px 0 0; color: #636e72; font-size: 1rem;">Select a lesson video. Our AI will analyze the transcript and build a custom practice test for you.</p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 380px; gap: 30px; align-items: start;">

        @* --- Left Column: AI Quiz Output --- *@
        <section>
            @* Skeleton Loader *@
            <div id="quizSkeleton" style="display: none;">
                <div class="skeleton-card">
                    <div class="skeleton-line" style="width: 40%; height: 24px; mb: 20px;"></div>
                    @for (int i = 0; i < 3; i++)
                    {
                        <div style="margin-bottom: 25px;">
                            <div class="skeleton-line" style="width: 90%;"></div>
                            <div class="skeleton-line" style="width: 100%; height: 45px; border-radius: 8px;"></div>
                            <div class="skeleton-line" style="width: 100%; height: 45px; border-radius: 8px;"></div>
                        </div>
                    }
                </div>
            </div>

            @* Quiz Content *@
            <div id="aiQuizContainer" style="@(string.IsNullOrEmpty(Model.ViewModel.GeneratedQuiz) ? "display:none;" : "") background: white; padding: 35px; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 30px; border-bottom: 1px solid #edf2f7; padding-bottom: 20px;">
                    <div>
                        <h3 style="margin: 0; color: #2d3436;">Generated Quiz</h3>
                        <small style="color: @accentColor; font-weight: 600;">Based on: @Model.ViewModel.SelectedLesson?.Title</small>
                    </div>
                    <button onclick="window.print()" style="background: #f1f2f6; border: none; padding: 8px 15px; border-radius: 6px; cursor: pointer; font-size: 0.8rem;">Print Quiz</button>
                </div>
                
                <div id="quizContent"></div>
            </div>

            @* Placeholder State *@
            @if (string.IsNullOrEmpty(Model.ViewModel.GeneratedQuiz))
            {
                <div id="quizPlaceholder" style="background: #fcfcfc; border: 2px dashed #d1d8e0; border-radius: 16px; padding: 100px 40px; text-align: center;">
                    <span style="font-size: 4rem;">📺</span>
                    <h3 style="color: #4b6584; margin-top: 20px;">No Lesson Selected</h3>
                    <p style="color: #778ca3;">Use the panel on the right to navigate your courses and select a specific lesson video to begin.</p>
                </div>
            }
        </section>

        @* --- Right Column: Cascading Selection Forms --- *@
        <aside style="position: sticky; top: 20px;">
            <div style="background: white; padding: 25px; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #f1f2f6;">
                <h4 style="margin: 0 0 20px 0; font-size: 1.1rem; color: #2d3436;">Navigation</h4>

                <form method="post" id="cascadingForm">
                    @* 1. ENROLLMENT *@
                    <div class="form-group">
                        <label class="label-tag">Course Enrollment</label>
                        <select asp-for="ViewModel.SelectedEnrollmentId" 
                                class="select-input"
                                onchange="submitHandler('LoadCourse')">
                            <option value="">-- Choose Course --</option>
                            @foreach (var e in Model.ViewModel.Enrollments)
                            {
                                <option value="@e.EnrollmentID">@e.Course.Title</option>
                            }
                        </select>
                    </div>

                    @* 2. CHAPTER *@
                    @if (Model.ViewModel.Chapters != null && Model.ViewModel.Chapters.Any())
                    {
                        <div class="form-group slide-in">
                            <label class="label-tag">Chapter</label>
                            <select asp-for="ViewModel.SelectedChapterId" 
                                    class="select-input"
                                    onchange="submitHandler('LoadChapter')">
                                <option value="">-- Choose Chapter --</option>
                                @foreach (var c in Model.ViewModel.Chapters)
                                {
                                    <option value="@c.ChapterID">@c.Title</option>
                                }
                            </select>
                        </div>
                    }

                    @* 3. LESSON *@
                    @if (Model.ViewModel.Lessons != null && Model.ViewModel.Lessons.Any())
                    {
                        <div class="form-group slide-in">
                            <label class="label-tag">Lesson Video</label>
                            <select asp-for="ViewModel.SelectedLessonId" 
                                    class="select-input"
                                    onchange="submitHandler('LoadLesson')">
                                <option value="">-- Choose Lesson --</option>
                                @foreach (var l in Model.ViewModel.Lessons)
                                {
                                    <option value="@l.LessonID">@l.Title</option>
                                }
                            </select>
                        </div>
                    }

                    @* 4. GENERATE ACTION *@
                    @if (Model.ViewModel.SelectedLessonId.HasValue)
                    {
                        <div class="generate-box">
                            <div style="margin-bottom: 15px;">
                                <div style="font-size: 0.75rem; color: #636e72; text-transform: uppercase; letter-spacing: 1px;">AI Context</div>
                                <div style="font-size: 0.9rem; font-weight: 600;">@Model.ViewModel.SelectedCourse.Grade.Name • @Model.ViewModel.SelectedCourse.Subject.Name</div>
                            </div>
                            
                            <button type="submit" asp-page-handler="GenerateQuiz" onclick="startGeneration()"
                                    class="btn-generate">
                                ⚡ Generate Practice Quiz
                            </button>
                        </div>
                    }
                </form>
            </div>
            
            <div style="margin-top: 20px; font-size: 0.8rem; color: #a5b1c2; text-align: center;">
                Powered by Gemini AI • Content extracted from video transcript
            </div>
        </aside>

    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .form-group { margin-bottom: 20px; }
    .label-tag { display: block; font-size: 0.75rem; font-weight: 700; color: #4b6584; text-transform: uppercase; margin-bottom: 8px; }
    .select-input { width: 100%; padding: 12px; border: 2px solid #edf2f7; border-radius: 10px; font-size: 0.95rem; color: #2d3436; transition: all 0.2s; background: #fff; cursor: pointer; }
    .select-input:focus { border-color: @primaryColor; outline: none; }
    
    .btn-generate { width: 100%; background: @primaryColor; color: white; border: none; padding: 15px; border-radius: 12px; font-weight: 800; cursor: pointer; transition: 0.3s; box-shadow: 0 4px 15px rgba(72, 52, 212, 0.3); }
    .btn-generate:hover { background: @accentColor; transform: translateY(-2px); }
    
    .generate-box { background: #f0f3ff; padding: 20px; border-radius: 12px; border: 1px solid #d1d8ff; margin-top: 10px; }
    
    .slide-in { animation: slideIn 0.3s ease-out; }
    @@keyframes slideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* Skeleton Loading UI */
    .skeleton-card { background: white; padding: 35px; border-radius: 16px; }
    .skeleton-line { background: #f1f2f6; height: 15px; margin-bottom: 12px; border-radius: 4px; position: relative; overflow: hidden; }
    .skeleton-line::after { content: ""; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.6), transparent); animation: loading 1.5s infinite; }
    @@keyframes loading { from { transform: translateX(-100%); } to { transform: translateX(100%); } }
</style>

<script>
    function submitHandler(handlerName) {
        const form = document.getElementById('cascadingForm');
        form.action = `?handler=${handlerName}`;
        form.submit();
    }

    function startGeneration() {
        document.getElementById('quizPlaceholder').style.display = 'none';
        document.getElementById('aiQuizContainer').style.display = 'none';
        document.getElementById('quizSkeleton').style.display = 'block';
    }

    // AI Result Handling
    document.addEventListener("DOMContentLoaded", function () {
        const aiJson = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ViewModel.GeneratedQuiz));
        if (!aiJson) return;

        try {
            // Remove markdown code blocks if the AI included them
            let cleanString = aiJson.replace(/```json/g, "").replace(/```/g, "").trim();
            
            // Ensure we find the array start/end
            const firstBracket = cleanString.indexOf('[');
            const lastBracket = cleanString.lastIndexOf(']');
            if (firstBracket !== -1 && lastBracket !== -1) {
                cleanString = cleanString.substring(firstBracket, lastBracket + 1);
            }

            const data = JSON.parse(cleanString);
            const questions = Array.isArray(data) ? data : (data.questions || []);
            
            let html = '';
            questions.forEach((q, i) => {
                html += `
                    <div style="margin-bottom: 30px; border: 1px solid #edf2f7; padding: 25px; border-radius: 12px;">
                        <p style="font-weight: 700; font-size: 1.1rem; color: #2d3436; margin-bottom: 20px;">
                            ${i + 1}. ${q.question || q.text}
                        </p>
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            ${(q.options || []).map(opt => `
                                <label style="display: flex; align-items: center; gap: 12px; padding: 15px; border: 2px solid #f8f9fa; border-radius: 10px; cursor: pointer; transition: 0.2s;" class="opt-label">
                                    <input type="radio" name="q${i}" style="width: 18px; height: 18px; accent-color: @primaryColor;">
                                    <span>${opt}</span>
                                </label>
                            `).join('')}
                        </div>
                        <div style="margin-top: 20px;">
                            <button onclick="this.nextElementSibling.style.display='block'; this.style.display='none'" 
                                    style="color: @primaryColor; background: none; border: none; font-weight: 700; cursor: pointer; font-size: 0.9rem;">
                                Check Answer & Explanation
                            </button>
                            <div style="display:none; background: #f0f7ff; padding: 20px; border-radius: 8px; border-left: 5px solid @primaryColor; margin-top: 10px;">
                                <strong style="color: #084298;">Correct: ${q.correct_answer || q.answer}</strong>
                                <p style="margin: 8px 0 0; font-size: 0.9rem; color: #334155;">${q.explanation || ''}</p>
                            </div>
                        </div>
                    </div>
                `;
            });
            document.getElementById('quizContent').innerHTML = html;
        } catch (e) {
            console.error("JSON Parse Fail:", e);
            document.getElementById('quizContent').innerHTML = `<div style="color:red">The AI returned an invalid quiz format. Please try generating again.</div>`;
        }
    });
</script>